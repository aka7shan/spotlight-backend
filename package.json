{
  "name": "spotlight-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Spotlight Portfolio backend API (Hono + Drizzle + Supabase Postgres)",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env --import tsx src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@hono/node-server": "^2.0.3",
    "@hono/zod-validator": "^0.8.0",
    "@supabase/supabase-js": "^2.107.0",
    "@upstash/redis": "^1.38.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.22",
    "jose": "^6.2.3",
    "mammoth": "^1.12.0",
    "postgres": "^3.4.9",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.41",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "tsx": "^4.22.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.4"
  }
}
