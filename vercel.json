{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run typecheck",
  "functions": {
    "api/health.ts": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/(.*)", "destination": "/api" }
  ]
}
