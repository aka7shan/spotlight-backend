# ---------------------------------------------------------------------------
# Spotlight backend environment
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.
# ---------------------------------------------------------------------------

# Where the local dev server listens
PORT=8787
NODE_ENV=development

# Where the frontend is hosted (used for CORS allow-list, comma-separated)
CORS_ORIGINS=http://localhost:5173

# Corporate-network escape hatch — uncomment if you see SELF_SIGNED_CERT_IN_CHAIN
# errors from Supabase/JWKS fetches. ONLY set this for local dev, never in prod.
# See .env for the full explanation.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ---------------------------------------------------------------------------
# Supabase
# Get these from https://supabase.com/dashboard/project/<id>/settings/api
# ---------------------------------------------------------------------------

# https://<project-ref>.supabase.co
SUPABASE_URL=

# Public anon key (safe to expose in browser; backend uses it for JWT verification)
SUPABASE_ANON_KEY=

# Service role key — SECRET. Never expose to the frontend. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret (only needed if you want to verify HS256 tokens locally;
# normally the backend verifies via Supabase's JWKS endpoint — no secret needed)
# SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# Database (Postgres — Supabase pooler connection string)
# Get this from https://supabase.com/dashboard/project/<id>/settings/database
# Use the "Connection pooling" -> "Transaction" string for serverless.
# ---------------------------------------------------------------------------

DATABASE_URL=
