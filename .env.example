# ---------------------------------------------------------------------------
# Spotlight backend environment
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.
# ---------------------------------------------------------------------------

# Where the local dev server listens
PORT=8787
NODE_ENV=development

# Where the frontend is hosted (CORS allow-list, comma-separated, no trailing slash)
# Local:  http://localhost:5173
# Prod:   https://spotlight-portfolio-ten.vercel.app
CORS_ORIGINS=http://localhost:5173

# Corporate-network escape hatch — uncomment if you see SELF_SIGNED_CERT_IN_CHAIN
# errors from Supabase/JWKS fetches. ONLY set this for local dev, never in prod.
# See .env for the full explanation.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ---------------------------------------------------------------------------
# Supabase
# Get these from https://supabase.com/dashboard/project/<id>/settings/api
# ---------------------------------------------------------------------------

# https://<project-ref>.supabase.co
SUPABASE_URL=

# Public anon key (safe to expose in browser; backend uses it for JWT verification)
SUPABASE_ANON_KEY=

# Service role key — optional for /v1/me today (profile uses DATABASE_URL + user JWT).
# Add on Vercel if you add admin scripts later. Never expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret (only needed if you want to verify HS256 tokens locally;
# normally the backend verifies via Supabase's JWKS endpoint — no secret needed)
# SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# Database (Postgres — Supabase pooler connection string)
# Get this from https://supabase.com/dashboard/project/<id>/settings/database
# Use the "Connection pooling" -> "Transaction" string for serverless.
# ---------------------------------------------------------------------------

DATABASE_URL=

# ---------------------------------------------------------------------------
# Upstash Redis (optional but recommended for production)
#
# Used as a hot cache in front of the anonymous public-portfolio lookup
# (`GET /v1/p/:code`). When both vars are set the backend serves repeat
# views for the same short code from Redis (sub-ms). When unset the cache
# layer silently no-ops and every request hits Postgres — fine for local
# dev, less ideal for prod.
#
# Provision a free Upstash Redis from the Vercel marketplace:
#   https://vercel.com/marketplace/upstash
# After integration, the env vars are auto-populated for your project.
# ---------------------------------------------------------------------------

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
